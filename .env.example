# 실제 키는 .env 에 넣는다 (.env 는 gitignore). 이 파일을 복사해서 채우면 된다:
#   cp .env.example .env

# ── Upstage Solar (기본 제공자, 무료 테스트) ──
# solar-embedding-1-large / solar-pro. OpenAI 호환 API.
UPSTAGE_API_KEY=

# ── Naver CLOVA Studio (대안, 무료 테스트) ──
NAVER_CLOVA_API_KEY=
# 구 API Gateway 방식이면 함께 필요할 수 있음:
# NAVER_APIGW_KEY=

# ── OpenAI (후순위, 유료 — 성능 미달 시만) ──
OPENAI_API_KEY=

# 활성 제공자는 configs/settings.yaml 의 providers 에서 선택 (기본 upstage).
# 키만 채우면 되고, 제공자 전환은 settings 수정 + 커밋으로 한다(실험 기록).
